#include "kernel/types.h"
#include "kernel/stat.h"
#include "kernel/fs.h"
#include "kernel/fcntl.h"
#include "user/user.h"

#include "snapshot.h"

#define MAX_PATH 128
#define BUFFER_SIZE 512

char buffer[BUFFER_SIZE];


// ----------------------------------------
// copy_file()
// ----------------------------------------
void
copy_file(char *src, char *dst)
{
    int fd_src, fd_dst, n;

    fd_src = open(src, O_RDONLY);

    if(fd_src < 0){
        printf("ERROR: cannot open %s\n", src);
        return;
    }

    fd_dst = open(dst, O_CREATE | O_WRONLY);

    if(fd_dst < 0){
        printf("ERROR: cannot create %s\n", dst);
        close(fd_src);
        return;
    }

    while((n = read(fd_src, buffer, sizeof(buffer))) > 0){
        write(fd_dst, buffer, n);
    }

    close(fd_src);
    close(fd_dst);
}


// ----------------------------------------
// get_filename()
// ----------------------------------------
char*
get_filename(char *path)
{
    char *p = path + strlen(path);

    while(p >= path && *p != '/')
        p--;

    return p + 1;
}


// ----------------------------------------
// ensure snapshot folder exists
// ----------------------------------------
void
ensure_snapshot_dir(char *name)
{
    mkdir("snapshots");

    char full[128];
    strcpy(full, "snapshots/");
    strcpy(full + strlen(full), name);

    mkdir(full);
}


// ----------------------------------------
// create snapshot from file
// ----------------------------------------
void
create_snapshot(char *snapshot_name)
{
    int fd;
    struct stat st;
    char path[MAX_PATH];

    fd = open("snapshot_data.txt", O_RDONLY);

    if(fd < 0){
        printf("ERROR: no snapshot data found. Run scanner first.\n");
        return;
    }

    ensure_snapshot_dir(snapshot_name);

    char base[128];
    strcpy(base, "snapshots/");
    strcpy(base + strlen(base), snapshot_name);

    printf("=== Snapshot Creation Started ===\n");

    while(1){

        // read struct stat
        if(read(fd, &st, sizeof(st)) != sizeof(st))
            break;

        // read path string
        int i = 0;
        char c;

        while(read(fd, &c, 1) == 1 && c != '\0'){
            path[i++] = c;
        }
        path[i] = '\0';

        // skip directories
        if(st.type == T_DIR)
            continue;

        char dst[128];

        strcpy(dst, base);
        strcpy(dst + strlen(dst), "/");
        strcpy(dst + strlen(dst), get_filename(path));

        copy_file(path, dst);

        printf("Copied: %s -> %s\n", path, dst);
    }

    close(fd);

    printf("=== Snapshot Created: %s ===\n", snapshot_name);
}


// ----------------------------------------
int main(int argc, char *argv[])
{
    if(argc < 2){
        printf("Usage: snapshot_creator <snapshot_name>\n");
        exit(1);
    }

    create_snapshot(argv[1]);

    exit(0);
}
