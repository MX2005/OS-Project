#include "kernel/types.h"
#include "kernel/stat.h"
#include "kernel/fs.h"
#include "kernel/fcntl.h"
#include "user/user.h"

#include "snapshot.h"

#define MAX_PATH 128
#define BUFFER_SIZE 512

char buffer[BUFFER_SIZE];


// ----------------------------------------
// copy_file()
// Copies content from src to dst
// ----------------------------------------
void
copy_file(char *src, char *dst)
{
    int fd_src, fd_dst, n;

    fd_src = open(src, O_RDONLY);

    if(fd_src < 0){
        printf("ERROR: cannot open source file %s\n", src);
        return;
    }

    fd_dst = open(dst, O_CREATE | O_WRONLY);

    if(fd_dst < 0){
        printf("ERROR: cannot create destination file %s\n", dst);
        close(fd_src);
        return;
    }

    while((n = read(fd_src, buffer, sizeof(buffer))) > 0){
        write(fd_dst, buffer, n);
    }

    close(fd_src);
    close(fd_dst);
}


// ----------------------------------------
// get_filename()
// Extracts file name from full path
// ----------------------------------------
char*
get_filename(char *path)
{
    char *p = path + strlen(path);

    while(p >= path && *p != '/')
        p--;

    return p + 1;
}


// ----------------------------------------
// ensure_snapshot_dir()
// Creates snapshot base directory
// ----------------------------------------
void
ensure_snapshot_dir(char *snapshot_name)
{
    mkdir("snapshots");

    char full[128];
    strcpy(full, "snapshots/");
    strcpy(full + strlen(full), snapshot_name);

    mkdir(full);
}


// ----------------------------------------
// create_snapshot()
// Main Part 2 logic (uses Part 1 data)
// ----------------------------------------
void
create_snapshot(char *snapshot_name)
{
    if(file_count == 0){
        printf("ERROR: No scanned files found. Run scanner first.\n");
        return;
    }

    ensure_snapshot_dir(snapshot_name);

    char base[128];
    strcpy(base, "snapshots/");
    strcpy(base + strlen(base), snapshot_name);

    printf("=== Snapshot Creation Started ===\n");

    for(int i = 0; i < file_count; i++){

        // skip directories
        if(files[i].type == T_DIR)
            continue;

        char dst[128];

        strcpy(dst, base);
        strcpy(dst + strlen(dst), "/");
        strcpy(dst + strlen(dst), get_filename(files[i].path));

        copy_file(files[i].path, dst);

        printf("Copied: %s -> %s\n",
               files[i].path,
               dst);
    }

    printf("=== Snapshot Created: %s ===\n", snapshot_name);
}


// ----------------------------------------
// main()
// Usage:
// snapshot_creator <snapshot_name>
// ----------------------------------------
int
main(int argc, char *argv[])
{
    if(argc < 2){
        printf("Usage: snapshot_creator <snapshot_name>\n");
        exit(1);
    }

    create_snapshot(argv[1]);

    exit(0);
}
